# Feishu / Lark credentials
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# Required
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# Optional – set to "lark" for global (non-China) tenants, or a full https:// URL
# for private deployments.  Defaults to "feishu".
FEISHU_DOMAIN=feishu

# Optional – only needed if you configured an Encrypt Key in the Feishu console.
# FEISHU_ENCRYPT_KEY=
